# PostgreSQL connection string (provided by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT tokens — use a long random string
JWT_SECRET=change-me-to-a-random-secret

# Port the backend listens on (Railway sets this automatically)
PORT=3000

# Full URL of the deployed frontend (set this after Vercel deploy)
FRONTEND_URL=https://your-app.vercel.app

# Microsoft Graph API / Azure AD (für Outlook-Kalender-Sync)
# Azure AD App Registration: https://portal.azure.com → App registrations
# Required scopes: Calendars.ReadWrite, offline_access, User.Read
MS_CLIENT_ID=your-azure-app-client-id
MS_CLIENT_SECRET=your-azure-app-client-secret
MS_TENANT_ID=your-azure-tenant-id-or-common
MS_REDIRECT_URI=http://localhost:3003/api/microsoft/callback
